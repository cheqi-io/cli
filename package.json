{
  "name": "@cheqi/cli",
  "version": "0.3.2",
  "description": "Cheqi CLI for agent-friendly encrypted receipt workflows",
  "license": "MIT",
  "author": "Cheqi",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cheqi-io/cli.git"
  },
  "bugs": {
    "url": "https://github.com/cheqi-io/cli/issues"
  },
  "homepage": "https://cheqi.io",
  "keywords": [
    "cheqi",
    "cli",
    "receipt",
    "digital-receipt",
    "encryption",
    "agent"
  ],
  "type": "module",
  "bin": {
    "cheqi": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node ./dist/index.js schema session create > /dev/null && node ./dist/index.js schema receipts submit > /dev/null && node ./dist/index.js schema receipts submit-download > /dev/null && node --test test/*.test.js",
    "prepublishOnly": "npm test"
  },
  "dependencies": {
    "@cheqi/sdk": "^0.5.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20"
  }
}
